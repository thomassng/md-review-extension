{
  "manifest_version": 3,
  "name": "Markdown Rich Review for GitHub Pull Requests",
  "version": "2.1.0",
  "description": "Enhances GitHub PR diff view for Markdown files with rich preview, line-level comment indicators, and click-to-source navigation.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": [
        "utils/domHelpers.js",
        "content-script.js"
      ],
      "css": ["styles/reviewPane.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "64": "icons/icon64.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "64": "icons/icon64.png"
    },
    "default_title": "Markdown Rich Review for GitHub Pull Requests"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://github.com/*"]
    }
  ]
}
